// My YT Automation Studio — database schema
// PostgreSQL configuration optimized for Prisma 7 and Supabase integration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Channels ────────────────────────────────────────────────────────────────
model Channel {
  id               String   @id @default(cuid())
  name             String
  niche            String   @default("")
  language         String   @default("English")
  country          String   @default("United States")
  status           String   @default("active") // active | paused | growth | new
  monetized        Boolean  @default(false)
  adsenseAccount   String   @default("")
  logoUrl          String   @default("")
  bannerUrl        String   @default("")
  description      String   @default("")
  keywords         String   @default("") // comma separated
  socialLinks      String   @default("{}") // JSON string
  notes            String   @default("")
  goals            String   @default("") // free text
  subscribers      Int      @default(0)
  views            Int      @default(0)
  watchHours       Float    @default(0)
  revenue          Float    @default(0)
  rpm              Float    @default(0)
  healthScore      Int      @default(80) // 0-100
  color            String   @default("emerald")
  youtubeChannelId String?  @unique // real YouTube channel ID for sync matching
  source           String   @default("manual") // manual | youtube
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  videos       Video[]
  cards        Card[]
  tasks        Task[]
  transactions Transaction[]
  scripts      Script[]
  events       CalendarEvent[]
  snapshots    AnalyticsSnapshot[]
  youtubeConn  YoutubeConnection?
  userId       String?   
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Videos ──────────────────────────────────────────────────────────────────
model Video {
  id             String    @id @default(cuid())
  channelId      String
  channel        Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title          String
  description    String    @default("")
  keywords       String    @default("")
  tags           String    @default("")
  script         String    @default("")
  hook           String    @default("")
  cta            String    @default("")
  thumbnailUrl   String    @default("")
  voiceOverUrl   String    @default("")
  editingStatus  String    @default("not_started") // not_started | in_progress | done
  publishDate    DateTime?
  seoScore       Int       @default(0)
  videoUrl       String    @default("")
  youtubeVideoId String?   @unique // real YouTube video ID for sync dedupe
  likes          Int       @default(0)
  comments       Int       @default(0)
  duration       String    @default("") // ISO 8601 duration e.g. PT10M30S
  category       String    @default("")
  privacyStatus  String    @default("public") // public | unlisted | private
  source         String    @default("manual") // manual | youtube
  views          Int       @default(0)
  ctr            Float     @default(0)
  retention      Float     @default(0)
  watchTime      Float     @default(0) // hours
  revenue        Float     @default(0)
  notes          String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  scripts ScriptsOnVideos[]
}

// ─── Scripts to Videos Relation (Many-to-Many Fix) ───────────────────────────
model ScriptsOnVideos {
  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  videoId  String
  video    Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@id([scriptId, videoId])
}

// ─── Content Planner (Kanban) ────────────────────────────────────────────────
model Card {
  id          String    @id @default(cuid())
  channelId   String?
  channel     Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  title       String
  description String    @default("")
  stage       String    @default("ideas") // ideas | research | writing | voice | editing | thumbnail | seo | scheduled | published | archive
  priority    String    @default("medium") // low | medium | high
  position    Int       @default(0)
  dueDate     DateTime?
  tags        String    @default("")
  assignee    String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Tasks ───────────────────────────────────────────────────────────────────
model Task {
  id          String      @id @default(cuid())
  channelId   String?
  channel     Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  title       String
  description String      @default("")
  priority    String      @default("medium") // low | medium | high | urgent
  status      String      @default("todo") // todo | in_progress | done
  category    String      @default("general")
  progress    Int         @default(0) // 0-100
  dueDate     DateTime?
  reminder    DateTime?
  assigneeId  String?
  assignee    TeamMember? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Team ────────────────────────────────────────────────────────────────────
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("Manager") // Script Writer | Editor | Voice Artist | Thumbnail Designer | SEO | Manager
  email     String   @default("")
  avatarUrl String   @default("")
  status    String   @default("active") // active | inactive
  rate      Float    @default(0)
  skills    String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[] @relation("TaskAssignee")
}

// ─── Trend Research ──────────────────────────────────────────────────────────
model TrendItem {
  id           String   @id @default(cuid())
  topic        String
  competitor   String   @default("")
  keyword      String   @default("")
  searchVolume Int      @default(0)
  difficulty   Int      @default(0) // 0-100
  opportunity  Int      @default(0) // 0-100
  category     String   @default("general")
  bookmarked   Boolean  @default(false)
  notes        String   @default("")
  source       String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── File Library ────────────────────────────────────────────────────────────
model FileAsset {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("document") // script | voiceover | video | music | thumbnail | brand | logo | document
  url       String   @default("")
  size      String   @default("")
  folder    String   @default("General")
  tags      String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Finance ─────────────────────────────────────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  channelId   String?
  channel     Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  type        String   @default("income") // income | expense
  category    String   @default("general") // adsense | sponsorship | merch | software | freelancer | equipment | tax | other
  amount      Float    @default(0)
  description String   @default("")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Goals ───────────────────────────────────────────────────────────────────
model Goal {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("yearly") // yearly | subscriber | revenue | upload | daily_habit
  target    Float    @default(0)
  current   Float    @default(0)
  period    String   @default("2025") // year / month / week
  unit      String   @default("") // subscribers | $ | videos | etc
  color     String   @default("emerald")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Automation workflows ────────────────────────────────────────────────────
model Workflow {
  id          String   @id @default(cuid())
  name        String
  videoTitle  String   @default("")
  channelName String   @default("")
  stages      String   @default("[]") // JSON array of {key,label,done}
  progress    Int      @default(0)
  status      String   @default("active") // active | completed | paused
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Notes / Sticky notes ────────────────────────────────────────────────────
model Note {
  id        String   @id @default(cuid())
  title     String   @default("")
  content   String   @default("")
  color     String   @default("emerald")
  pinned    Boolean  @default(false)
  type      String   @default("quick") // quick | sticky
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Habits ──────────────────────────────────────────────────────────────────
model Habit {
  id        String   @id @default(cuid())
  name      String
  streak    Int      @default(0)
  goal      Int      @default(7) // per week
  history   String   @default("[]") // JSON array of ISO date strings done
  color     String   @default("emerald")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Reading list ────────────────────────────────────────────────────────────
model ReadingItem {
  id        String   @id @default(cuid())
  title     String
  url       String   @default("")
  category  String   @default("general")
  status    String   @default("todo") // todo | reading | done
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Bookmarks ───────────────────────────────────────────────────────────────
model Bookmark {
  id        String   @id @default(cuid())
  title     String
  url       String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Activity feed ───────────────────────────────────────────────────────────
model Activity {
  id        String   @id @default(cuid())
  type      String   @default("info") // info | success | warning | error
  message   String
  section   String   @default("dashboard")
  createdAt DateTime @default(now())
}

// ─── AI Chat history (legacy simple chat log) ────────────────────────────────
model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user | assistant
  content   String
  tool      String   @default("general") // ideas | titles | scripts | ...
  createdAt DateTime @default(now())
}

// ─── Users (auth) ────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String    @default("")
  emailVerified DateTime?
  resetToken    String?
  resetTokenExp DateTime?
  verifyToken   String?
  verifyTokenExp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  youtubeConns YoutubeConnection[]
  channels     Channel[]
}

// ─── YouTube OAuth connection (encrypted tokens + sync state) ────────────────
model YoutubeConnection {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeChannelId  String    @unique
  channelTitle      String    @default("")
  // Encrypted (AES-256-GCM) access token
  accessTokenEnc    String    @default("")
  refreshTokenEnc   String    @default("")
  scope             String    @default("")
  tokenExpiresAt    DateTime?
  status            String    @default("active") // active | expired | revoked | error
  lastSyncAt        DateTime?
  lastSyncStatus    String    @default("never") // never | success | partial | failed | in_progress
  lastSyncError     String    @default("")
  lastSyncProgress  Int       @default(0) // 0-100
  autoSync          Boolean   @default(true)
  syncIntervalHrs   Int       @default(6)
  channelId         String?   @unique // link to local Channel record (created/updated on sync)
  channel           Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  syncLogs SyncLog[]
}

// ─── Sync log (every sync attempt) ───────────────────────────────────────────
model SyncLog {
  id             String            @id @default(cuid())
  youtubeConnId  String
  connection     YoutubeConnection @relation(fields: [youtubeConnId], references: [id], onDelete: Cascade)
  status         String            @default("started") // started | success | partial | failed
  resource       String            @default("full") // full | channel | videos
  message        String            @default("")
  error          String            @default("")
  itemsProcessed Int               @default(0)
  durationMs     Int               @default(0)
  createdAt      DateTime          @default(now())
}

// ─── Analytics snapshot (time-series of channel metrics) ─────────────────────
model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  channelId       String
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  subscribers     Int      @default(0)
  views           Int      @default(0)
  videos          Int      @default(0)
  watchTimeHours  Float    @default(0)
  revenue         Float    @default(0)
  source          String   @default("youtube") // youtube | manual
  capturedAt      DateTime @default(now())
}

// ─── Accounts / Sessions / Verification (NextAuth) ───────────────────────────
model Account {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
}

// ─── Scripts (standalone, linkable to Video/Channel) ─────────────────────────
model Script {
  id        String   @id @default(cuid())
  title     String
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  content   String   @default("")
  hook      String   @default("")
  cta       String   @default("")
  tags      String   @default("")
  folder    String   @default("General")
  status    String   @default("draft") // draft | review | final
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos ScriptsOnVideos[]
}

// ─── Calendar Events (standalone, dedicated) ─────────────────────────────────
model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  date        DateTime
  endDate     DateTime?
  type        String    @default("publish") // publish | meeting | deadline | reminder | upload
  channelId   String?
  channel     Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  color       String    @default("emerald")
  reminder    DateTime?
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Notifications ───────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info | success | warning | error
  section   String   @default("dashboard")
  read      Boolean  @default(false)
  actionUrl String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Settings (key-value, per-user via userId) ───────────────────────────────
model Setting {
  id        String   @id @default(cuid())
  userId    String   @default("local")
  key       String
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

// ─── AI History (full prompt/response log with category + favorites) ─────────
model AIHistory {
  id        String   @id @default(cuid())
  tool      String   @default("general")
  category  String   @default("text") // text | image | audio | speech
  prompt    String
  response  String   @default("")
  model     String   @default("zai")
  favorite  Boolean  @default(false)
  meta      String   @default("{}") // JSON (e.g. image url, audio url)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}